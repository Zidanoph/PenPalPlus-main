# --- PenPal+ backend configuration ---

# Secret used to sign JWTs. CHANGE THIS in production (e.g. `openssl rand -hex 32`).
SECRET_KEY=dev-secret-change-me-0123456789abcdef0123456789abcdef

# Access token lifetime (minutes) and refresh token lifetime (days)
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database. SQLite by default (zero setup). For PostgreSQL:
#   DATABASE_URL=postgresql+psycopg2://penpal:penpal@localhost:5432/penpal
DATABASE_URL=sqlite:///./penpal.db

# CORS origins (comma separated) — the Vite dev server runs on 5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Letter delivery simulation ---
# Average "postal speed". Higher = letters arrive sooner. Real airmail ~ 60-120.
DELIVERY_SPEED_KMH=140
# Floor / ceiling on travel time (hours)
DELIVERY_MIN_HOURS=2
DELIVERY_MAX_HOURS=168
# Set true ONLY for demos/tests: letters arrive in DEMO_DELIVERY_SECONDS instead.
DEMO_FAST_DELIVERY=false
DEMO_DELIVERY_SECONDS=20
